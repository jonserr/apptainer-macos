#!/usr/bin/env bash
#
# apptainer wrapper for macOS using Docker Desktop
# Runs the official Apptainer container so `apptainer` works on macOS
#
set -euo pipefail

PINNED_APPT_VER="__APPT_VER__"

if [[ -n "${APPT_VER:-}" ]]; then
    APPTAINER_VERSION="${APPT_VER}"
elif [[ -n "${APPT_VER_ENV:-}" ]]; then
    APPTAINER_VERSION="${APPT_VER_ENV}"
elif [[ "${PINNED_APPT_VER}" == "__APPT_VER__" || -z "${PINNED_APPT_VER}" ]]; then
    APPTAINER_VERSION="1.5.1"
else
    APPTAINER_VERSION="${PINNED_APPT_VER}"
fi

IMAGE="ghcr.io/apptainer/apptainer:${APPTAINER_VERSION}"

command -v docker >/dev/null 2>&1 || {
    echo "Docker CLI not found. Install Docker Desktop or run install.sh." >&2
    exit 127
}

start_docker_desktop() {
    if docker info >/dev/null 2>&1; then
        return 0
    fi

    if [[ ! -d "/Applications/Docker.app" ]]; then
        echo "Docker Desktop is not installed at /Applications/Docker.app." >&2
        echo "Install it with:" >&2
        echo "  brew install --cask docker-desktop" >&2
        exit 1
    fi

    echo "Docker is not running. Launching /Applications/Docker.app..." >&2
    open "/Applications/Docker.app" >/dev/null 2>&1 || {
        echo "Failed to launch /Applications/Docker.app." >&2
        exit 1
    }

    printf "Waiting for Docker daemon" >&2

    for _ in $(seq 1 90); do
        if docker info >/dev/null 2>&1; then
            printf " ready.\n" >&2
            return 0
        fi

        printf "." >&2
        sleep 2
    done

    printf "\n" >&2
    echo "Docker did not become ready." >&2
    echo "Open Docker Desktop manually, accept any first-run prompts, then retry." >&2
    exit 1
}

start_docker_desktop

USER_NAME="${USER:-$(id -un)}"

export APPTAINER_TMPDIR="${APPTAINER_TMPDIR:-/tmp/apptainer-tmp-${USER_NAME}}"
export APPTAINER_CACHEDIR="${APPTAINER_CACHEDIR:-/tmp/apptainer-cache-${USER_NAME}}"

mkdir -p "${APPTAINER_TMPDIR}" "${APPTAINER_CACHEDIR}"

TTY_ARGS=()
if [[ -t 0 && -t 1 ]]; then
    TTY_ARGS=(-it)
fi

HOST_MOUNTS=(
    -v /Users:/Users
    -v /tmp:/tmp
    -w "$PWD"
)

exec docker run --rm "${TTY_ARGS[@]}" --privileged \
    -v /var/run/docker.sock:/var/run/docker.sock \
    -e APPTAINER_TMPDIR="${APPTAINER_TMPDIR}" \
    -e APPTAINER_CACHEDIR="${APPTAINER_CACHEDIR}" \
    "${HOST_MOUNTS[@]}" \
    --entrypoint apptainer \
    "${IMAGE}" "$@"
